{
  "name": "wxnn-photo-manager",
  "version": "2.3.0",
  "description": "无限暖暖相册管理工具",
  "private": true,
  "main": "dist/main/main/index.js",
  "author": "QianLu",
  "scripts": {
    "dev": "npm run build:main && electron .",
    "clean": "node -e \"const fs=require('fs');const p=require('path');const d=p.join(__dirname,'dist','renderer','assets');if(fs.existsSync(d)){fs.rmSync(d,{recursive:true,force:true});console.log('[clean] removed dist/renderer/assets')}\"",
    "build": "npm run clean && npm run build:main && npm run build:renderer",
    "build:main": "tsc -p src/main/tsconfig.json",
    "build:renderer": "vite build",
    "preview": "vite preview",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\" \"scripts/**/*.{ts,js}\" \"*.{ts,js,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\" \"scripts/**/*.{ts,js}\" \"*.{ts,js,json,md}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "i18n:check": "ts-node --project tsconfig.scripts.json scripts/check-i18n-keys.ts",
    "preview:check": "ts-node --project tsconfig.scripts.json scripts/check-preview-drift.ts",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3,sharp,koffi",
    "commit": "cz",
    "commitlint": "commitlint --from=HEAD~1 --to=HEAD",
    "commitlint:check": "commitlint --edit",
    "prepare": "husky || true"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.{js,jsx,json,css,md}": [
      "prettier --write"
    ],
    "scripts/**/*.{ts,js}": [
      "prettier --write"
    ],
    "*.{ts,js,json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@formkit/auto-animate": "^0.10.0",
    "better-sqlite3": "^12.11.1",
    "exifr": "^7.1.3",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "i18next": "^26.3.6",
    "koffi": "^3.1.1",
    "motion": "^12.42.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.10",
    "sharp": "^0.35.3",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@electron/rebuild": "^4.2.0",
    "@eslint/js": "^10.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "autoprefixer": "^10.5.4",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "electron": "^30.5.1",
    "electron-builder": "^26.15.3",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^15.3.0",
    "png-to-ico": "^3.0.2",
    "postcss": "^8.5.20",
    "prettier": "^3.9.5",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^5.4.21",
    "vitest": "^1.6.1"
  },
  "build": {
    "appId": "com.qianlu.wxnn-photo-manager",
    "productName": "无限暖暖相册管理工具",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "resources/**/*"
    ],
    "asarUnpack": [
      "**/ffmpeg-static/**",
      "**/ffprobe-static/**",
      "**/better-sqlite3/**",
      "**/sharp/**",
      "**/@img/**",
      "**/koffi/**",
      "**/nuan5_decryption.dll"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icons/icon.ico",
      "signAndEditExecutable": false,
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "无限暖暖相册管理工具"
    }
  }
}
