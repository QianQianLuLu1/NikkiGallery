{
  "name": "wxnn-photo-manager",
  "version": "2.3.0",
  "description": "无限暖暖相册管理工具",
  "main": "dist/main/main/index.js",
  "author": "QianLu",
  "scripts": {
    "dev": "npm run build:main && electron .",
    "clean": "node -e \"const fs=require('fs');const p=require('path');const d=p.join(__dirname,'dist','renderer','assets');if(fs.existsSync(d)){fs.rmSync(d,{recursive:true,force:true});console.log('[clean] removed dist/renderer/assets')}\"",
    "build": "npm run clean && npm run build:main && npm run build:renderer",
    "build:main": "tsc -p src/main/tsconfig.json",
    "build:renderer": "vite build",
    "preview": "vite preview",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\" \"scripts/**/*.{ts,js}\" \"*.{ts,js,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\" \"scripts/**/*.{ts,js}\" \"*.{ts,js,json,md}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "i18n:check": "ts-node --project tsconfig.scripts.json scripts/check-i18n-keys.ts",
    "preview:check": "ts-node --project tsconfig.scripts.json scripts/check-preview-drift.ts"
  },
  "dependencies": {
    "@formkit/auto-animate": "^0.9.0",
    "better-sqlite3": "^9.4.0",
    "exifr": "^7.1.3",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "i18next": "^26.3.4",
    "koffi": "^3.1.0",
    "motion": "^12.42.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^17.0.8",
    "sharp": "^0.33.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/coverage-v8": "^1.6.0",
    "autoprefixer": "^10.4.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.6.0",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.4.0",
    "prettier": "^3.9.5",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.61.1",
    "vite": "^5.0.0",
    "vitest": "^1.6.0"
  },
  "build": {
    "appId": "com.qianlu.wxnn-photo-manager",
    "productName": "无限暖暖相册管理工具",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "resources/**/*"
    ],
    "asarUnpack": [
      "**/ffmpeg-static/**",
      "**/ffprobe-static/**",
      "**/better-sqlite3/**",
      "**/sharp/**",
      "**/@img/**",
      "**/nuan5_decryption.dll"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icons/icon.ico",
      "signAndEditExecutable": false,
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "无限暖暖相册管理工具"
    }
  }
}
